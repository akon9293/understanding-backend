<!doctype html>
<html>

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/stylesheets/style.css">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
  <div class="main w-full min-h-screen bg-zinc-900 text-white">
    <div class="form p-10">
      <form action="/create" method="POST">
        <input class="block px-5 py-2 w-full bg-zinc-800 rounded-md" type="text" name="title"
          placeholder="Give me a Title">
        <textarea class="block mt-2 px-5 py-2 w-full resize-none bg-zinc-800 rounded-md" name="description"
          placeholder="Write your task's description"></textarea>
        <input class="mt-2 bg-blue-600 px-5 py-2" type="submit" value="Create Task">
      </form>
    </div>

    <% if (files.length > 0) { %>
      <div class="tasts p-10 flex gap-3 flex-wrap">
        <% files.forEach(function(val) { %>
          <div class="w-72 px-3 py-4 rounded-md bg-zinc-800">
            <h1 class="text-white text-3xl tracking-tighter"><%= val.title %></h1>
            <p class="text-zinc-400 mt-2"><%= val.description %></p>
            <a href="/tasks/<%= val._id %>" class="text-blue-500 inline-block mt-3">Read more.</a>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="p-10">
        <h3 class="text-zinc-600">No tasks yet</h3>
      </div>
    <% } %>
  </div>
</body>

</html>